<definitions xmlns="http://ws.apache.org/ns/synapse">
    <api name="ForEachTestAPI" context="/foreach-test">
        <resource uri-template="/json" methods="POST">
            <inSequence>
                <foreach expression="json-eval($.info)" id="foreach_1o" continueLoopOnFailure="true">
                    <sequence>
                        <filter regex="EFG" source="json-eval($.name)">
                            <then>
                                <log level="full"/>
                                <sequence key="asdf"/>
                            </then>
                            <else>
                                <log level="full"/>
                            </else>
                        </filter>
                    </sequence>
                </foreach>
                <respond/>
            </inSequence>
            <faultSequence>
                <property name="HTTP_SC" value="500" scope="axis2"/>
                <respond/>
            </faultSequence>
        </resource>
        <resource uri-template="/xml" methods="POST">
            <inSequence>
                <foreach expression="//info" id="foreach_1so" continueLoopOnFailure="true">
                    <sequence>
                        <filter regex="EFG" source="//name">
                            <then>
                                <log level="full"/>
                                <sequence key="ffff"/>
                            </then>
                            <else>
                                <log level="full"/>
                            </else>
                        </filter>
                    </sequence>
                </foreach>
                <respond/>
                <respond/>
            </inSequence>
            <faultSequence>
                <property name="HTTP_SC" value="500" scope="axis2"/>
                <respond/>
            </faultSequence>
        </resource>
    </api>
</definitions>
